# Copy to `.env` at the repo root if you need local overrides.

# Optional: FastAPI local JSON store. Defaults to `.krail/store.json`.
# LOCAL_STORE_PATH=.krail/store.json

# Federal Reserve API for example FRED hydration configs.
FRED_API_KEY=

# Optional API listen port for your own launcher scripts.
# RAIL_API_PORT=8000

# Engine paths are normally set by the Makefile.
# ENGINE_ROOT=.../packages/engine
# RAIL_ANALYSIS_DIR=.../packages/engine/analysis
# RAIL_TRANSFORM_DIR=.../packages/engine/transforms

# LLM providers. Set whichever provider matches AI_MODEL.
# AI_MODEL=gpt-4o
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# Python execution sandbox controls.
# RAIL_EXECUTE_ENABLED=false
# RAIL_EXECUTE_MODE=subprocess
