# Copy to `.env` at the repo root (gitignored). Used by Makefile and optional tooling.
#
# Hydration jobs (POST /api/v1/jobs) need Convex HTTP access: full URL + deploy key.
# The FastAPI app also loads `packages/web/.env.local` for NEXT_PUBLIC_* (see web example).

# Convex — same https deployment URL as in packages/web/.env.local (NEXT_PUBLIC_CONVEX_URL).
# Use the full URL including https:// (e.g. https://your-team.convex.cloud).
CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Convex → Settings → Deploy keys (server-only; never NEXT_PUBLIC_*).
CONVEX_DEPLOY_KEY=

# Federal Reserve API (pipeline steps that use fred_*.yaml).
FRED_API_KEY=

# Optional API listen port for start-api.ps1 / kill-api-port.ps1 when 8000 is stuck on Windows
# (ghost LISTEN / WinError 10048). Match NEXT_PUBLIC_API_URL in packages/web/.env.local.
# RAIL_API_PORT=8001

# Optional — Makefile / start-api.ps1 usually set these when you use them.
# ENGINE_ROOT=.../packages/engine
# RAIL_ANALYSIS_DIR=.../packages/engine/analysis
# RAIL_TRANSFORM_DIR=.../packages/engine/transforms

# LLM (agent / SQL translate) — set whichever provider you use with AI_MODEL.
# AI_MODEL=gemini/gemini-2.0-flash
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# Python execution (POST /api/v1/execute, agent execute_python, POST /api/v1/analysis/run-code)
# RAIL_EXECUTE_ENABLED=false
# RAIL_EXECUTE_MODE=subprocess
# RAIL_EXECUTE_DOCKER_IMAGE=rail-python:local

# GitHub App (for bidirectional sync)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=   # Paste the PEM key as a single-line string with \n
GITHUB_WEBHOOK_SECRET=
