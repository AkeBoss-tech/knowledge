# FastAPI service (packages/api)
CONVEX_URL=https://colorless-elephant-150.convex.cloud
CONVEX_DEPLOY_KEY=          # from Convex dashboard → Settings → Deploy Keys
FRED_API_KEY=               # from https://fred.stlouisfed.org/docs/api/api_key.html
STORAGE_BACKEND=local       # local | s3
ENGINE_ROOT=../engine       # relative to packages/api when running locally

# Next.js (packages/web)
NEXT_PUBLIC_CONVEX_URL=https://colorless-elephant-150.convex.cloud
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
