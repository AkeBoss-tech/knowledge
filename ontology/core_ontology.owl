<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/rutgers_ontology.owl"
         xmlns="http://example.org/rutgers_ontology.owl#">

<owl:Ontology rdf:about="http://example.org/rutgers_ontology.owl"/>

<owl:ObjectProperty rdf:about="#isPartOf">
  <rdfs:domain rdf:resource="#Municipality"/>
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:range rdf:resource="#State"/>
  <rdfs:range rdf:resource="#County"/>
  <owl:inverseOf rdf:resource="#hasPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPart">
  <owl:inverseOf rdf:resource="#isPartOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#locatedIn">
  <rdfs:domain rdf:resource="#Individual"/>
  <rdfs:domain rdf:resource="#Municipality"/>
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:range rdf:resource="#Municipality"/>
  <rdfs:range rdf:resource="#State"/>
  <rdfs:range rdf:resource="#County"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasName">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasPopulation">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Municipality"/>
  <rdfs:domain rdf:resource="#State"/>
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasFIPS">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#State"/>
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasIncome">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Individual"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#State">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#County">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Municipality">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Individual">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>


</rdf:RDF>
