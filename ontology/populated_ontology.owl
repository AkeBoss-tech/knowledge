<owl:Ontology rdf:about="http://example.org/rutgers_ontology.owl"/>

<owl:ObjectProperty rdf:about="#isPartOf">
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:domain rdf:resource="#Municipality"/>
  <rdfs:range rdf:resource="#State"/>
  <rdfs:range rdf:resource="#County"/>
  <owl:inverseOf rdf:resource="#hasPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#locatedIn">
  <rdfs:domain rdf:resource="#County"/>
  <rdfs:domain rdf:resource="#Individual"/>
  <rdfs:domain rdf:resource="#Municipality"/>
  <rdfs:range rdf:resource="#County"/>
  <rdfs:range rdf:resource="#Municipality"/>
  <rdfs:range rdf:resource="#State"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#measuredFor">
  <rdfs:domain rdf:resource="#Measure"/>
  <rdfs:range rdf:resource="#State"/>
  <rdfs:range rdf:resource="#County"/>
  <rdfs:range rdf:resource="#Municipality"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPart">
  <owl:inverseOf rdf:resource="#isPartOf"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasName">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasPopulation">
