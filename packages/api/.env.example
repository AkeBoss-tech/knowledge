# Optional local overrides when running uvicorn from `packages/api`.
# The app loads, in order: packages/web/.env.local → repo root .env → this file.
# Prefer setting Convex + secrets in the repo root `.env` so one place stays canonical.

CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
CONVEX_DEPLOY_KEY=
FRED_API_KEY=

# RAIL_EXECUTE_ENABLED=false
# RAIL_EXECUTE_MODE=subprocess
# RAIL_EXECUTE_DOCKER_IMAGE=
